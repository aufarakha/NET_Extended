{
  "manifest_version": 3,
  "name": "Notion Empty Trash Extended",
  "short_name": "NET_Extended",
  "version": "1.2.0",
  "description": "Adds the legacy Empty Trash button directly inside Notion.",
  "icons": {
    "16": "icons/net_ext_16.png",
    "32": "icons/net_ext_32.png",
    "48": "icons/net_ext_48.png",
    "128": "icons/net_ext_128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://app.notion.com/*",
    "https://www.notion.com/*",
    "https://www.notion.so/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://app.notion.com/*",
        "https://www.notion.com/*",
        "https://www.notion.so/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "NET_Extended",
    "default_icon": {
      "16": "icons/net_ext_16.png",
      "32": "icons/net_ext_32.png",
      "48": "icons/net_ext_48.png",
      "128": "icons/net_ext_128.png"
    },
    "default_popup": "popup.html"
  }
}
